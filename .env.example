# TubeWiki 환경변수 템플릿 — 이 파일을 복사해 `.env.local`을 만들고 값을 채우세요.
#   cp .env.example .env.local

# [필수] Claude 요약 API 키 (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# [선택] 요약 모델 (기본: claude-sonnet-5)
SUMMARY_MODEL=claude-sonnet-5

# [필수] YouTube Data API v3 키. 게시일·조회수·설명·태그·길이 등 풍부한 메타데이터 수집.
#        발급: https://console.cloud.google.com/ → YouTube Data API v3 사용 설정 → API 키 생성
YOUTUBE_API_KEY=

# [선택] 생성된 위키 MD를 저장할 폴더 (기본: ./output)
WIKI_OUTPUT_DIR=./output
